{
  "editorModules": {
    "description": "2D 编辑器模块配置 - 通用配置",
    "version": "1.0.0",
    "lastUpdated": "2026-02-26",
    "engine": "canvas2d",

    "phase1": {
      "name": "第一阶段：核心 Canvas 基础（同步加载）",
      "description": "2D 编辑器启动的最小依赖",
      "priority": "critical",
      "loadTime": "~300-500ms",
      "totalSize": "~150KB",
      "modules": [
        {
          "id": "canvas-2d-utils",
          "name": "Canvas2DUtils.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/Canvas2DUtils.js",
          "size": "30KB",
          "required": true,
          "description": "Canvas 2D 工具库，提供绘制、计算、检测等功能",
          "dependencies": [],
          "checkFunction": "typeof Canvas2DUtils !== 'undefined'"
        },
        {
          "id": "base-editor-2d",
          "name": "BaseEditor2D.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/BaseEditor2D.js",
          "size": "80KB",
          "required": true,
          "description": "2D 编辑器基类，提供对象管理、选择、变换、撤销/重做等核心功能",
          "dependencies": ["canvas-2d-utils"],
          "checkFunction": "typeof Base2DEditor !== 'undefined'"
        },
        {
          "id": "grid-system",
          "name": "GridSystem.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/GridSystem.js",
          "size": "20KB",
          "required": true,
          "description": "网格系统，支持网格显示、对齐、自定义网格大小",
          "dependencies": ["canvas-2d-utils"],
          "checkFunction": "typeof GridSystem !== 'undefined'"
        }
      ]
    },

    "phase2": {
      "name": "第二阶段：类型特定工具（异步加载）",
      "description": "根据编辑器类型加载特定功能模块",
      "priority": "high",
      "loadTime": "~500-800ms（后台）",
      "totalSize": "~200KB",
      "modules": {
        "2d-strategy": [
          {
            "id": "pathfinding-editor",
            "name": "PathfindingEditor.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/PathfindingEditor.js",
            "size": "40KB",
            "required": true,
            "description": "寻路编辑器，A* 算法可视化、障碍标记、路径预览",
            "dependencies": ["grid-system"],
            "checkFunction": "typeof PathfindingEditor !== 'undefined'"
          },
          {
            "id": "battle-preview",
            "name": "BattlePreview.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/BattlePreview.js",
            "size": "35KB",
            "required": true,
            "description": "战斗预览，单位放置、攻击范围、技能范围可视化",
            "dependencies": ["pathfinding-editor"],
            "checkFunction": "typeof BattlePreview !== 'undefined'"
          }
        ],
        "2d-metroidvania": [
          {
            "id": "collision-body-editor",
            "name": "CollisionBodyEditor.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/CollisionBodyEditor.js",
            "size": "45KB",
            "required": true,
            "description": "碰撞体编辑器，创建和编辑物理碰撞体",
            "dependencies": ["base-editor-2d"],
            "checkFunction": "typeof CollisionBodyEditor !== 'undefined'"
          },
          {
            "id": "physics-preview",
            "name": "PhysicsPreview.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/PhysicsPreview.js",
            "size": "30KB",
            "required": true,
            "description": "物理预览，平台碰撞、重力模拟、碰撞检测可视化",
            "dependencies": ["collision-body-editor"],
            "checkFunction": "typeof PhysicsPreview !== 'undefined'"
          }
        ],
        "2d-rpg": [
          {
            "id": "npc-editor",
            "name": "NPCEditor.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/NPCEditor.js",
            "size": "50KB",
            "required": true,
            "description": "NPC 编辑器，NPC 创建、编辑、AI 行为配置",
            "dependencies": ["base-editor-2d"],
            "checkFunction": "typeof NPCEditor !== 'undefined'"
          },
          {
            "id": "dialogue-editor",
            "name": "DialogueEditor.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/DialogueEditor.js",
            "size": "40KB",
            "required": true,
            "description": "对话编辑器，对话树、分支、选项管理",
            "dependencies": ["npc-editor"],
            "checkFunction": "typeof DialogueEditor !== 'undefined'"
          },
          {
            "id": "quest-system",
            "name": "QuestSystem.js",
            "type": "module",
            "source": "local",
            "url": "/static/js/unity-editor/QuestSystem.js",
            "size": "35KB",
            "required": true,
            "description": "任务系统，任务创建、条件、奖励配置",
            "dependencies": ["dialogue-editor"],
            "checkFunction": "typeof QuestSystem !== 'undefined'"
          }
        ]
      }
    },

    "phase3": {
      "name": "第三阶段：高级功能（按需加载）",
      "description": "可选的高级功能模块，用户需要时加载",
      "priority": "low",
      "loadTime": "~500-1000ms（按需）",
      "totalSize": "~300KB",
      "modules": [
        {
          "id": "animation-editor-2d",
          "name": "AnimationEditor2D.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AnimationEditor2D.js",
          "size": "80KB",
          "required": false,
          "enabled": false,
          "description": "2D 动画编辑器，帧动画、精灵动画、动画序列",
          "dependencies": ["base-editor-2d"],
          "checkFunction": "typeof AnimationEditor2D !== 'undefined'"
        },
        {
          "id": "tilemap-editor-2d",
          "name": "TilemapEditor2D.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/TilemapEditor2D.js",
          "size": "70KB",
          "required": false,
          "enabled": false,
          "description": "图块地图编辑器，图块绘制、层管理、自动图块",
          "dependencies": ["grid-system"],
          "checkFunction": "typeof TilemapEditor2D !== 'undefined'"
        },
        {
          "id": "script-editor-2d",
          "name": "ScriptEditor2D.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/ScriptEditor2D.js",
          "size": "100KB",
          "required": false,
          "enabled": false,
          "description": "脚本编辑器，JavaScript 脚本编写、语法高亮、调试",
          "dependencies": ["base-editor-2d"],
          "checkFunction": "typeof ScriptEditor2D !== 'undefined'"
        },
        {
          "id": "asset-browser-2d",
          "name": "AssetBrowser2D.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AssetBrowser2D.js",
          "size": "50KB",
          "required": false,
          "enabled": false,
          "description": "资源浏览器，纹理、精灵、音效资源管理",
          "dependencies": ["base-editor-2d"],
          "checkFunction": "typeof AssetBrowser2D !== 'undefined'"
        }
      ]
    },

    "loadingStrategy": {
      "description": "2D 编辑器加载策略",
      "phase1Loading": {
        "type": "synchronous",
        "parallelRequests": true,
        "cacheStrategy": "persistent",
        "maxConcurrent": 3,
        "timeout": 15000
      },
      "phase2Loading": {
        "type": "asynchronous",
        "trigger": "editorReady",
        "method": "requestIdleCallback",
        "fallback": "setTimeout",
        "fallbackDelay": 500,
        "maxConcurrent": 2,
        "timeout": 30000
      },
      "phase3Loading": {
        "type": "lazy",
        "trigger": "user-action",
        "method": "dynamic-import",
        "cacheStrategy": "temporary",
        "timeout": 60000
      }
    },

    "performanceTargets": {
      "initialLoadTime": "300-500ms",
      "editorReadyTime": "500-800ms",
      "completeLoadTime": "1000-1500ms",
      "firstPaint": "200ms",
      "interactionReady": "500ms",
      "memoryUsage": "<50MB"
    },

    "editorTypeConfigs": {
      "2d-strategy": {
        "name": "2D 策略战棋",
        "requiredModules": ["canvas-2d-utils", "base-editor-2d", "grid-system", "pathfinding-editor", "battle-preview"],
        "optionalModules": ["animation-editor-2d", "tilemap-editor-2d"],
        "features": ["网格编辑", "寻路算法", "战斗预览", "单位管理"]
      },
      "2d-metroidvania": {
        "name": "2D 恶魔城",
        "requiredModules": ["canvas-2d-utils", "base-editor-2d", "grid-system", "collision-body-editor", "physics-preview"],
        "optionalModules": ["animation-editor-2d", "tilemap-editor-2d"],
        "features": ["碰撞编辑", "物理模拟", "平台系统", "重力设置"]
      },
      "2d-rpg": {
        "name": "2D RPG",
        "requiredModules": ["canvas-2d-utils", "base-editor-2d", "grid-system", "npc-editor", "dialogue-editor", "quest-system"],
        "optionalModules": ["animation-editor-2d", "script-editor-2d", "asset-browser-2d"],
        "features": ["NPC 编辑", "对话系统", "任务系统", "存档管理"]
      }
    },

    "cdnUrls": {},
    "localUrls": {
      "canvas-2d-utils": "/static/js/unity-editor/Canvas2DUtils.js",
      "base-editor-2d": "/static/js/unity-editor/BaseEditor2D.js",
      "grid-system": "/static/js/unity-editor/GridSystem.js",
      "pathfinding-editor": "/static/js/unity-editor/PathfindingEditor.js",
      "battle-preview": "/static/js/unity-editor/BattlePreview.js",
      "collision-body-editor": "/static/js/unity-editor/CollisionBodyEditor.js",
      "physics-preview": "/static/js/unity-editor/PhysicsPreview.js",
      "npc-editor": "/static/js/unity-editor/NPCEditor.js",
      "dialogue-editor": "/static/js/unity-editor/DialogueEditor.js",
      "quest-system": "/static/js/unity-editor/QuestSystem.js",
      "editor-factory": "/static/js/unity-editor/EditorFactory.js"
    },

    "browserSupport": {
      "requirements": [
        "Canvas 2D 支持",
        "ES6 Promise 支持",
        "ES6 async/await 支持",
        "RequestIdleCallback（可选）"
      ],
      "tested": ["Chrome 80+", "Firefox 75+", "Safari 13+", "Edge 80+"]
    },

    "debugMode": {
      "enabled": false,
      "logLevel": "info",
      "showLoadingProgress": true,
      "showPerformanceMetrics": true,
      "recordNetworkRequests": true
    }
  }
}

