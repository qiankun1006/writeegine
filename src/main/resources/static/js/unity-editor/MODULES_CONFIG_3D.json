{
  "editorModules": {
    "description": "3D 编辑器模块配置 - 射击游戏专用",
    "version": "1.0.0",
    "lastUpdated": "2026-02-26",
    "engine": "threejs",

    "phase1": {
      "name": "第一阶段：Three.js 核心（同步加载）",
      "description": "3D 编辑器启动的最小依赖",
      "priority": "critical",
      "loadTime": "~800-1000ms",
      "totalSize": "~700KB",
      "modules": [
        {
          "id": "three.js",
          "name": "Three.js",
          "type": "library",
          "source": "CDN",
          "url": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js",
          "size": "600KB",
          "required": true,
          "description": "3D 图形库，渲染基础",
          "dependencies": [],
          "checkFunction": "typeof THREE !== 'undefined'"
        },
        {
          "id": "orbit-controls",
          "name": "OrbitControls",
          "type": "module",
          "source": "CDN",
          "url": "https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js",
          "size": "15KB",
          "required": true,
          "description": "摄像机轨道控制器，支持旋转、缩放、平移",
          "dependencies": ["three.js"],
          "checkFunction": "typeof THREE !== 'undefined' && typeof THREE.OrbitControls !== 'undefined'"
        },
        {
          "id": "unity-renderer",
          "name": "UnityRenderer.js",
          "type": "module",
            "source": "local",
          "url": "/static/js/unity-editor/UnityRenderer.js",
          "size": "100KB",
          "required": true,
          "description": "Three.js 渲染抽象层，管理场景、对象、材质",
          "dependencies": ["three.js", "orbit-controls"],
          "checkFunction": "typeof UnityRenderer !== 'undefined'"
        },
        {
          "id": "unity-editor",
          "name": "UnityEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityEditor.js",
          "size": "80KB",
          "required": true,
          "description": "编辑器核心逻辑，处理选择、变换、操作历史",
          "dependencies": ["unity-renderer"],
          "checkFunction": "typeof UnityEditor !== 'undefined'"
        }
      ]
    },

    "phase2": {
      "name": "第二阶段：3D 射击特定功能（异步加载）",
      "description": "射击游戏特定功能模块",
      "priority": "high",
      "loadTime": "~500-800ms（后台）",
      "totalSize": "~250KB",
      "modules": [
        {
          "id": "selection-system",
          "name": "SelectionSystem.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/SelectionSystem.js",
          "size": "25KB",
          "required": true,
          "description": "选择系统，3D 对象选择、包围盒、变换工具",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof SelectionSystem !== 'undefined'"
        },
        {
          "id": "raycasting-tool",
          "name": "RaycastingTool.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/RaycastingTool.js",
          "size": "30KB",
          "required": true,
          "description": "射线检测工具，3D 空间拾取、瞄准线、轨迹计算",
          "dependencies": ["selection-system"],
          "checkFunction": "typeof RaycastingTool !== 'undefined'"
        },
        {
          "id": "lighting-editor",
          "name": "LightingEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/LightingEditor.js",
          "size": "50KB",
          "required": true,
          "description": "光照编辑器，创建和管理场景光源（环境、方向、点、聚光）",
          "dependencies": ["unity-renderer"],
          "checkFunction": "typeof LightingEditor !== 'undefined'"
        },
        {
          "id": "particle-system-editor",
          "name": "ParticleSystemEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/ParticleSystemEditor.js",
          "size": "60KB",
          "required": true,
          "description": "粒子系统编辑器，创建和管理粒子效果（爆炸、火焰、烟雾）",
          "dependencies": ["unity-renderer"],
          "checkFunction": "typeof ParticleSystemEditor !== 'undefined'"
        }
      ]
    },

    "phase3": {
      "name": "第三阶段：高级物理和特效（可选加载）",
      "description": "可选的高级功能模块，物理引擎、音频等",
      "priority": "medium",
      "loadTime": "~800-1200ms（按需）",
      "totalSize": "~500KB",
      "modules": [
        {
          "id": "ammo.js",
          "name": "Ammo.js",
          "type": "library",
          "source": "CDN",
          "url": "https://cdn.jsdelivr.net/npm/ammo.js@0.0.10/builds/ammo.wasm.js",
          "size": "200KB",
          "required": false,
          "enabled": false,
          "description": "物理引擎库，提供刚体、碰撞、约束等功能",
          "dependencies": [],
          "checkFunction": "typeof Ammo !== 'undefined'"
        },
        {
          "id": "unity-physics",
          "name": "UnityPhysics.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityPhysics.js",
          "size": "50KB",
          "required": false,
          "enabled": false,
          "description": "Ammo.js 集成模块，将物理引擎集成到编辑器",
          "dependencies": ["ammo.js", "unity-renderer"],
          "checkFunction": "typeof UnityPhysics !== 'undefined'"
        },
        {
          "id": "animation-system",
          "name": "AnimationSystem.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AnimationSystem.js",
          "size": "80KB",
          "required": false,
          "enabled": false,
          "description": "动画系统，支持关键帧动画、骨骼动画、动画状态机",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof AnimationSystem !== 'undefined'"
        },
        {
          "id": "script-editor",
          "name": "ScriptEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/ScriptEditor.js",
          "size": "100KB",
          "required": false,
          "enabled": false,
          "description": "脚本编辑器，支持 JavaScript 脚本编写和调试",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof ScriptEditor !== 'undefined'"
        },
        {
          "id": "asset-library",
          "name": "AssetLibrary.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AssetLibrary.js",
          "size": "100KB",
          "required": false,
          "enabled": false,
          "description": "资源库管理，支持纹理、模型、预制体的导入和管理",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof AssetLibrary !== 'undefined'"
        }
      ]
    },

    "loadingStrategy": {
      "description": "3D 射击编辑器加载策略",
      "phase1Loading": {
        "type": "synchronous",
        "parallelCDNRequests": true,
        "cacheStrategy": "persistent",
        "maxConcurrent": 3,
        "timeout": 30000
      },
      "phase2Loading": {
        "type": "asynchronous",
        "trigger": "editorReady",
        "method": "requestIdleCallback",
        "fallback": "setTimeout",
        "fallbackDelay": 1000,
        "maxConcurrent": 2,
        "timeout": 60000
      },
      "phase3Loading": {
        "type": "lazy",
        "trigger": "user-action",
        "method": "fetch",
        "cacheStrategy": "temporary",
        "timeout": 120000
      }
    },

    "performanceTargets": {
      "initialLoadTime": "800-1000ms",
      "editorReadyTime": "1000-1200ms",
      "completeLoadTime": "2000-2500ms",
      "firstPaint": "500ms",
      "firstContentfulPaint": "800ms",
      "interactionReady": "1200ms",
      "memoryUsage": "<200MB"
    },

    "features": [
      {
        "name": "3D 场景编辑",
        "enabled": true,
        "requires": ["three.js", "unity-renderer", "unity-editor"]
      },
      {
        "name": "摄像机控制",
        "enabled": true,
        "requires": ["orbit-controls"]
      },
      {
        "name": "对象选择和变换",
        "enabled": true,
        "requires": ["selection-system", "raycasting-tool"]
      },
      {
        "name": "光照编辑",
        "enabled": true,
        "requires": ["lighting-editor"]
      },
      {
        "name": "粒子效果",
        "enabled": true,
        "requires": ["particle-system-editor"]
      },
      {
        "name": "物理模拟",
        "enabled": false,
        "requires": ["ammo.js", "unity-physics"]
      },
      {
        "name": "动画编辑",
        "enabled": false,
        "requires": ["animation-system"]
      },
      {
        "name": "脚本编辑",
        "enabled": false,
        "requires": ["script-editor"]
      },
      {
        "name": "资源管理",
        "enabled": false,
        "requires": ["asset-library"]
      }
    ],

    "cdnUrls": {
      "three.js": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js",
      "orbitControls": "https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js",
      "ammo.js": "https://cdn.jsdelivr.net/npm/ammo.js@0.0.10/builds/ammo.wasm.js"
    },

    "localUrls": {
      "unity-renderer": "/static/js/unity-editor/UnityRenderer.js",
      "unity-editor": "/static/js/unity-editor/UnityEditor.js",
      "selection-system": "/static/js/unity-editor/SelectionSystem.js",
      "raycasting-tool": "/static/js/unity-editor/RaycastingTool.js",
      "lighting-editor": "/static/js/unity-editor/LightingEditor.js",
      "particle-system-editor": "/static/js/unity-editor/ParticleSystemEditor.js",
      "unity-physics": "/static/js/unity-editor/UnityPhysics.js",
      "animations": "/static/js/unity-editor/AnimationSystem.js",
      "scripts": "/static/js/unity-editor/ScriptEditor.js",
      "assets": "/static/js/unity-editor/AssetLibrary.js",
      "loader": "/static/js/unity-editor/LazyLoader.js"
    },

    "browserSupport": {
      "requirements": [
        "WebGL 1.0 或更高",
        "ES6 Promise 支持",
        "ES6 async/await 支持",
        "WebWorker（可选）",
        "Service Worker（可选）"
      ],
      "tested": ["Chrome 90+", "Firefox 88+", "Safari 14+", "Edge 90+"]
    },

    "debugMode": {
      "enabled": false,
      "logLevel": "info",
      "showLoadingProgress": true,
      "showPerformanceMetrics": true,
      "recordNetworkRequests": true
    }
  }
}

