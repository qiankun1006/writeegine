{
  "editorType": "2d-strategy",
  "name": "2D 策略战棋编辑器",
  "version": "1.0.0",
  "modules": [
    {
      "id": "core",
      "name": "核心引擎",
      "priority": 1,
      "required": true,
      "scripts": [
        "/static/js/unity-editor/Canvas2DUtils.js",
        "/static/js/unity-editor/BaseEditor2D.js",
        "/static/js/unity-editor/EditorFactory.js"
      ],
      "styles": [],
      "size": "120KB"
    },
    {
      "id": "strategy-tools",
      "name": "策略编辑工具",
      "priority": 2,
      "required": true,
      "scripts": [
        "/static/js/unity-editor/GridSystem.js",
        "/static/js/unity-editor/PathfindingEditor.js",
        "/static/js/unity-editor/BattlePreview.js"
      ],
      "styles": [],
      "size": "150KB",
      "dependsOn": ["core"]
    },
    {
      "id": "ui-framework",
      "name": "UI 框架",
      "priority": 3,
      "required": true,
      "scripts": [
        "/static/js/unity-editor/UIComponents.js",
        "/static/js/unity-editor/PropertyPanel.js"
      ],
      "styles": [
        "/static/css/ui-components.css"
      ],
      "size": "80KB",
      "dependsOn": ["core"]
    },
    {
      "id": "advanced-features",
      "name": "高级功能",
      "priority": 4,
      "required": false,
      "scripts": [
        "/static/js/unity-editor/AIPathfinding.js",
        "/static/js/unity-editor/ScriptEditor.js"
      ],
      "styles": [],
      "size": "200KB",
      "dependsOn": ["strategy-tools"]
    }
  ],
  "loadingStrategy": "lazy",
  "cacheControl": {
    "enabled": true,
    "maxAge": 86400
  },
  "performance": {
    "minChunkSize": "20KB",
    "maxChunkSize": "500KB",
    "parallel": true,
    "maxParallel": 3
  }
}

