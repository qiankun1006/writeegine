{
  "editorModules": {
    "description": "Unity 编辑器模块配置",
    "version": "1.0.0",
    "lastUpdated": "2026-02-25",

    "phase1": {
      "name": "第一阶段：必需模块（同步加载）",
      "description": "编辑器启动的最小依赖，必须完全加载才能初始化",
      "priority": "critical",
      "loadTime": "~1 秒",
      "totalSize": "~965KB",
      "modules": [
        {
          "id": "three.js",
          "name": "Three.js",
          "type": "library",
          "source": "CDN",
          "url": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js",
          "size": "600KB",
          "required": true,
          "description": "3D 图形库，编辑器渲染基础",
          "dependencies": [],
          "checkFunction": "typeof THREE !== 'undefined'"
        },
        {
          "id": "orbit-controls",
          "name": "OrbitControls",
          "type": "module",
          "source": "CDN",
          "url": "https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js",
          "size": "15KB",
          "required": true,
          "description": "摄像机轨道控制器，支持旋转、缩放、平移",
          "dependencies": ["three.js"],
          "checkFunction": "typeof THREE !== 'undefined' && typeof THREE.OrbitControls !== 'undefined'"
        },
        {
          "id": "unity-renderer",
          "name": "UnityRenderer.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityRenderer.js",
          "size": "100KB",
          "required": true,
          "description": "Three.js 渲染抽象层，管理场景、对象、材质",
          "dependencies": ["three.js", "orbit-controls"],
          "checkFunction": "typeof UnityRenderer !== 'undefined'"
        },
        {
          "id": "unity-editor",
          "name": "UnityEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityEditor.js",
          "size": "80KB",
          "required": true,
          "description": "编辑器核心逻辑，处理选择、变换、操作历史",
          "dependencies": ["unity-renderer"],
          "checkFunction": "typeof UnityEditor !== 'undefined'"
        },
        {
          "id": "unity-ui",
          "name": "UnityUI.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityUI.js",
          "size": "100KB",
          "required": true,
          "description": "用户界面管理，处理工具栏、面板、属性编辑器交互",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof UnityUI !== 'undefined'"
        }
      ]
    },

    "phase2": {
      "name": "第二阶段：可选模块（异步后台加载）",
      "description": "增强编辑器功能的可选模块，在浏览器空闲时加载",
      "priority": "high",
      "loadTime": "~2-3 秒（后台）",
      "totalSize": "~650KB",
      "modules": [
        {
          "id": "ammo.js",
          "name": "Ammo.js",
          "type": "library",
          "source": "CDN",
          "url": "https://cdn.jsdelivr.net/npm/ammo.js@0.0.10/builds/ammo.wasm.js",
          "size": "200KB",
          "required": false,
          "enabled": false,
          "description": "物理引擎库，提供刚体、碰撞、约束等功能",
          "dependencies": [],
          "checkFunction": "typeof Ammo !== 'undefined'"
        },
        {
          "id": "unity-physics",
          "name": "UnityPhysics.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/UnityPhysics.js",
          "size": "50KB",
          "required": false,
          "enabled": false,
          "description": "Ammo.js 集成模块，将物理引擎集成到编辑器",
          "dependencies": ["ammo.js", "unity-renderer"],
          "checkFunction": "typeof UnityPhysics !== 'undefined'"
        },
        {
          "id": "animation-system",
          "name": "AnimationSystem.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AnimationSystem.js",
          "size": "80KB",
          "required": false,
          "enabled": false,
          "description": "动画系统，支持关键帧动画、骨骼动画、动画状态机",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof AnimationSystem !== 'undefined'"
        },
        {
          "id": "particle-system",
          "name": "ParticleSystem.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/ParticleSystem.js",
          "size": "70KB",
          "required": false,
          "enabled": false,
          "description": "粒子系统，支持粒子发射、材质、纹理动画",
          "dependencies": ["unity-renderer"],
          "checkFunction": "typeof ParticleSystem !== 'undefined'"
        },
        {
          "id": "script-editor",
          "name": "ScriptEditor.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/ScriptEditor.js",
          "size": "150KB",
          "required": false,
          "enabled": false,
          "description": "脚本编辑器，支持 JavaScript 脚本编写和调试",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof ScriptEditor !== 'undefined'"
        },
        {
          "id": "asset-library",
          "name": "AssetLibrary.js",
          "type": "module",
          "source": "local",
          "url": "/static/js/unity-editor/AssetLibrary.js",
          "size": "100KB",
          "required": false,
          "enabled": false,
          "description": "资源库管理，支持纹理、模型、预制体的导入和管理",
          "dependencies": ["unity-editor"],
          "checkFunction": "typeof AssetLibrary !== 'undefined'"
        }
      ]
    },

    "phase3": {
      "name": "第三阶段：资源预加载（可选）",
      "description": "常用资源的预加载，加速后续使用",
      "priority": "low",
      "loadTime": "~1-2 秒（空闲时）",
      "totalSize": "~10-50MB（取决于资源）",
      "categories": [
        {
          "type": "textures",
          "name": "纹理库",
          "description": "预加载常用纹理（如网格、棋盘等）",
          "examples": [
            "/assets/textures/grid.png",
            "/assets/textures/checkerboard.png",
            "/assets/textures/noise.png"
          ]
        },
        {
          "type": "models",
          "name": "模型库",
          "description": "预加载常用 3D 模型（低多边形）",
          "examples": [
            "/assets/models/primitives/cube.gltf",
            "/assets/models/primitives/sphere.gltf",
            "/assets/models/primitives/cylinder.gltf"
          ]
        },
        {
          "type": "sounds",
          "name": "音效库",
          "description": "预加载编辑器界面音效",
          "examples": [
            "/assets/sounds/click.wav",
            "/assets/sounds/success.wav",
            "/assets/sounds/error.wav"
          ]
        },
        {
          "type": "animations",
          "name": "动画库",
          "description": "预加载演示动画",
          "examples": [
            "/assets/animations/demo1.json",
            "/assets/animations/demo2.json"
          ]
        }
      ]
    },

    "loadingStrategy": {
      "description": "加载策略配置",
      "phase1Loading": {
        "type": "synchronous",
        "parallelCDNRequests": true,
        "cacheStrategy": "persistent",
        "maxConcurrent": 3,
        "timeout": 30000
      },
      "phase2Loading": {
        "type": "asynchronous",
        "trigger": "idle",
        "method": "requestIdleCallback",
        "fallback": "setTimeout",
        "fallbackDelay": 1000,
        "maxConcurrent": 2,
        "timeout": 60000
      },
      "phase3Loading": {
        "type": "lazy",
        "trigger": "user-action",
        "method": "fetch",
        "cacheStrategy": "temporary",
        "timeout": 120000
      }
    },

    "performanceTargets": {
      "initialLoadTime": "1000ms",
      "editorReadyTime": "1500ms",
      "completeLoadTime": "3000ms",
      "firstPaint": "500ms",
      "firstContentfulPaint": "800ms",
      "interactionReady": "1200ms"
    },

    "features": [
      {
        "name": "3D 场景编辑",
        "enabled": true,
        "requires": ["three.js", "unity-renderer", "unity-editor", "unity-ui"]
      },
      {
        "name": "摄像机控制",
        "enabled": true,
        "requires": ["orbit-controls"]
      },
      {
        "name": "物理模拟",
        "enabled": false,
        "requires": ["ammo.js", "unity-physics"]
      },
      {
        "name": "动画编辑",
        "enabled": false,
        "requires": ["animation-system"]
      },
      {
        "name": "粒子效果",
        "enabled": false,
        "requires": ["particle-system"]
      },
      {
        "name": "脚本编辑",
        "enabled": false,
        "requires": ["script-editor"]
      },
      {
        "name": "资源管理",
        "enabled": false,
        "requires": ["asset-library"]
      }
    ],

    "cdnUrls": {
      "three.js": "https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js",
      "orbitControls": "https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js",
      "ammo.js": "https://cdn.jsdelivr.net/npm/ammo.js@0.0.10/builds/ammo.wasm.js"
    },

    "localUrls": {
      "css": "/static/css/unity-editor.css",
      "renderer": "/static/js/unity-editor/UnityRenderer.js",
      "editor": "/static/js/unity-editor/UnityEditor.js",
      "ui": "/static/js/unity-editor/UnityUI.js",
      "physics": "/static/js/unity-editor/UnityPhysics.js",
      "animations": "/static/js/unity-editor/AnimationSystem.js",
      "particles": "/static/js/unity-editor/ParticleSystem.js",
      "scripts": "/static/js/unity-editor/ScriptEditor.js",
      "assets": "/static/js/unity-editor/AssetLibrary.js",
      "loader": "/static/js/unity-editor/LazyLoader.js"
    },

    "browserSupport": {
      "requirements": [
        "WebGL 1.0 或更高",
        "ES6 Promise 支持",
        "ES6 async/await 支持",
        "WebWorker（可选）",
        "Service Worker（可选）"
      ],
      "tested": ["Chrome 90+", "Firefox 88+", "Safari 14+", "Edge 90+"]
    },

    "debugMode": {
      "enabled": false,
      "logLevel": "info",
      "showLoadingProgress": true,
      "showPerformanceMetrics": true,
      "recordNetworkRequests": true
    }
  }
}

